// Estado del semáforo
estado = "rojo";

// Tiempo en rojo: 2 segundos antes de cambiar a verde
contador = 2 * 60;

// Posiciones aproximadas de las luces (en la imagen del fondo)
// Ajusta estos números según donde tengas las "O" del semáforo en tu fondo
luz_x = 470;        // X del centro de la primera luz roja (ajusta)
luz_y = 90;         // Y del centro
separacion = 75;    // Separación horizontal entre luces
radio_luz = 22;